{
  "name": "anvilwing",
  "version": "1.5.23",
  "description": "Claude Code–class Ink TUI coding agent (max thought, ultracode always on). Live follow-up queue, Shift+Tab permission modes, colored diffs, adversarial verifier — bring your own key.",
  "anvilwing": {
    "rulebookSchema": "src/contracts/schemas/agent-rules.schema.json"
  },
  "main": "dist/bin/anvilwing.js",
  "exports": {
    ".": "./dist/bin/anvilwing.js",
    "./capabilities": "./dist/capabilities/index.js"
  },
  "type": "module",
  "files": [
    "dist",
    "scripts/postinstall.cjs",
    "README.md",
    "assets",
    "agents",
    "LICENSE"
  ],
  "bin": {
    "anvilwing": "dist/bin/anvilwing.js"
  },
  "scripts": {
    "postinstall": "node scripts/postinstall.cjs",
    "prebuild": "npm run clean",
    "clean": "node -e \"const { rmSync } = require('fs'); for (const target of ['dist', '.tsbuildinfo']) { try { rmSync(target, { recursive: true, force: true, maxRetries: 10 }); } catch (error) { console.warn('Clean warning:', error.code, 'for', target); } }\"",
    "build": "tsc",
    "build:watch": "tsc --watch",
    "build:prod": "NODE_ENV=production MINIFY=true npm run build",
    "optimize": "node scripts/optimize-build.mjs",
    "release": "chmod +x scripts/create-release.sh && scripts/create-release.sh patch",
    "release:minor": "chmod +x scripts/create-release.sh && scripts/create-release.sh minor",
    "release:major": "chmod +x scripts/create-release.sh && scripts/create-release.sh major",
    "prepublishOnly": "npm run build",
    "pretest": "npm run build",
    "postbuild": "node scripts/postbuild.mjs",
    "cli": "node dist/bin/anvilwing.js",
    "dev": "node --loader ts-node/esm src/bin/anvilwing.ts",
    "dev:watch": "node --watch --loader ts-node/esm src/bin/anvilwing.ts",
    "start": "node dist/bin/anvilwing.js",
    "test": "jest --config jest.config.cjs",
    "test:watch": "jest --config jest.config.cjs --watch",
    "test:coverage": "jest --config jest.config.cjs --coverage",
    "lint": "eslint src/**/*.ts --max-warnings 200",
    "lint:fix": "eslint src/**/*.ts --fix",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "ai",
    "cli",
    "agent",
    "llm",
    "anvilwing",
    "code-assistant",
    "automation",
    "developer-tools"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Aroxora/anvilwing.git"
  },
  "bugs": {
    "url": "https://github.com/Aroxora/anvilwing/issues"
  },
  "homepage": "https://github.com/Aroxora/anvilwing#readme",
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.28.5",
    "@babel/preset-env": "^7.28.5",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@eslint/js": "^9.39.2",
    "@types/glob": "^8.1.0",
    "@types/gradient-string": "^1.1.6",
    "@types/jest": "30.0.0",
    "@types/node": "25.0.2",
    "@types/react": "^19.2.0",
    "@typescript-eslint/eslint-plugin": "8.49.0",
    "@typescript-eslint/parser": "8.49.0",
    "@xterm/headless": "^6.0.0",
    "babel-jest": "^30.2.0",
    "eslint": "9.39.2",
    "eslint-plugin-import": "^2.32.0",
    "ink-testing-library": "^4.0.0",
    "jest": "30.2.0",
    "node-pty": "^1.1.0",
    "ts-jest": "29.4.6",
    "ts-node": "^10.9.2",
    "typescript-eslint": "^8.50.0"
  },
  "overrides": {
    "uuid": "^14.0.0"
  },
  "dependencies": {
    "boxen": "^8.0.1",
    "braces": "^3.0.3",
    "chalk": "^5.6.2",
    "cli-spinners": "^3.3.0",
    "gradient-string": "^3.0.0",
    "ignore": "^7.0.5",
    "ink": "^7.0.1",
    "ink-spinner": "^5.0.0",
    "marked-terminal": "^7.3.0",
    "nanospinner": "1.2.2",
    "open": "^11.0.0",
    "openai": "^6.10.0",
    "ora": "^9.0.0",
    "react": "^19.2.0",
    "react-devtools-core": "^7.0.1",
    "typescript": "5.9.3"
  }
}
